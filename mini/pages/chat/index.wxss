/* ===== Design Tokens ===== */
page {
  --green: #2ecc71;
  --green-dk: #27ae60;
  --green-lt: #d5f5e3;
  --orange: #f39c12;
  --blue: #3498db;
  --purple: #9b59b6;
  --gray1: #f8f9fa;
  --gray2: #e9ecef;
  --gray3: #ced4da;
  --text: #212529;
  --text2: #495057;
  --text3: #888a8b;
  height: 100%;
}

/* ===== Page Layout ===== */
.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--gray1);
  overflow: hidden;
}

/* ===== Status Bar ===== */
.status-bar {
  background: #fff;
  flex-shrink: 0;
}

/* ===== Nav Bar ===== */
.nav-bar {
  background: #fff;
  padding: 12rpx 32rpx 20rpx;
  border-bottom: 1rpx solid var(--gray2);
  flex-shrink: 0;
}

.nav-bar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.nav-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text);
}

.nav-sub {
  font-size: 24rpx;
  color: var(--text3);
}

.nav-kcal {
  color: var(--green-dk);
  font-weight: 700;
}

.ai-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea, #764ba2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.calorie-bar-wrap {
  /* spacer */
}

.calorie-bar {
  height: 12rpx;
  background: var(--gray2);
  border-radius: 6rpx;
  overflow: hidden;
}

.calorie-bar-fill {
  height: 100%;
  border-radius: 6rpx;
  background: linear-gradient(90deg, var(--green), var(--orange));
  transition: width 0.4s ease;
}

/* ===== Chat Area ===== */
.chat-area {
  flex: 1;
  padding: 0 16rpx;
  box-sizing: border-box;
  overflow-y: auto;
  /*
   * 减轻「盯久了发晕」：略降线对比、拉大格距；底层极淡柔光打破满屏均匀格子的视觉噪声（线宽仍 12px）
   */
  background-color: #faf5e9;
  background-image:
    linear-gradient(rgba(101, 72, 48, 0.05) 12px, transparent 12px),
    linear-gradient(90deg, rgba(101, 72, 48, 0.05) 12px, transparent 12px),
    radial-gradient(ellipse 130% 90% at 50% 48%, rgba(255, 255, 255, 0.22) 0%, transparent 62%);
  background-size: 96rpx 96rpx, 96rpx 96rpx, 100% 100%;
  background-repeat: repeat, repeat, no-repeat;
}

.date-chip {
  text-align: center;
  padding: 20rpx 0 28rpx;
}

.date-chip text {
  background: var(--gray2);
  padding: 6rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: var(--text3);
}

/* ===== Bubble Row ===== */
.bubble-row {
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.bubble-row.right {
  flex-direction: row-reverse;
}

/* ===== Avatars ===== */
.avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

/* AI：透明底、完整展示贴纸（不裁圆、不 aspectFill 裁切） */
.avatar.ai-avatar-icon {
  width: 68rpx;
  height: 68rpx;
  border-radius: 0;
  background: transparent;
  overflow: visible;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.user-avatar-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  background: var(--green-lt);
  overflow: hidden;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-img.avatar-img--ai {
  border-radius: 0;
}

.bubble-content {
  max-width: 540rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  align-self: flex-end;
}

/* 营养卡片/营养确认卡片：占满最大宽度，与长文字气泡一致 */
.bubble-content--wide {
  width: 540rpx;
  max-width: 100%;
}

.bubble-row.right .bubble-content {
  align-self: flex-end;
}

/* ===== Bubbles ===== */
.bubble {
  padding: 24rpx 28rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text);
  word-break: break-all;
}

.ai-bubble {
  align-self: flex-start;
  background: #fff;
  border-bottom-left-radius: 8rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.user-bubble {
  align-self: flex-end;
  background: linear-gradient(135deg, var(--green), var(--green-dk));
  color: #fff;
  border-bottom-right-radius: 8rpx;
}

.suggestion-bubble {
  margin-top: 0;
}

/* ===== Typing Indicator ===== */
.typing {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 4rpx 0;
}

.typing-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--gray3);
}

.dot1 { animation: bounce 1.2s infinite ease-in-out 0s; }
.dot2 { animation: bounce 1.2s infinite ease-in-out 0.2s; }
.dot3 { animation: bounce 1.2s infinite ease-in-out 0.4s; }

@keyframes bounce {
  0%, 80%, 100% { transform: translateY(0); }
  40% { transform: translateY(-10rpx); }
}

/* ===== Image Bubble ===== */
.img-bubble {
  width: 320rpx;
  height: 240rpx;
  border-radius: 28rpx;
  overflow: hidden;
  position: relative;
  background: #e0e0e0;
}

.food-image {
  width: 100%;
  height: 100%;
  border-radius: 28rpx;
}

/* 上传中遮罩 */
.img-uploading-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.img-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: img-spin 0.8s linear infinite;
}

@keyframes img-spin {
  to { transform: rotate(360deg); }
}

.img-uploading-text {
  font-size: 22rpx;
  color: #fff;
}

/* 识别到的食物名 overlay */
.img-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.5));
  padding: 16rpx 20rpx;
}

.img-overlay text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
}

/* 上传失败角标 */
.img-fail-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #f44336;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
}

/* ===== Nutrition Card ===== */
.nutrition-card {
  background: linear-gradient(135deg, #f8fff9, #eafaf1);
  border: 2rpx solid #c3e6cb;
  border-radius: 28rpx;
  padding: 28rpx;
  width: 480rpx;
}

.food-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text);
  display: block;
  margin-bottom: 20rpx;
}

.nut-row {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.nut-item {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx 8rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.nut-val {
  font-size: 28rpx;
  font-weight: 700;
  display: block;
}

.nut-val.green  { color: var(--green-dk); }
.nut-val.blue   { color: var(--blue); }
.nut-val.purple { color: var(--purple); }
.nut-val.orange { color: var(--orange); }

.nut-lbl {
  font-size: 20rpx;
  color: var(--text3);
  display: block;
}

.card-calorie-bar-wrap {
  /* container */
}

.card-calorie-labels {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.card-calorie-lbl-text {
  font-size: 22rpx;
  color: var(--text3);
}

.card-calorie-lbl-val {
  font-size: 22rpx;
  color: var(--green-dk);
  font-weight: 600;
}

.card-calorie-bar {
  height: 16rpx;
  background: var(--gray2);
  border-radius: 8rpx;
  overflow: hidden;
}

.card-calorie-fill {
  height: 100%;
  border-radius: 8rpx;
  background: linear-gradient(90deg, var(--green), var(--orange));
  max-width: 100%;
}

/* ===== History Loading ===== */
.history-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 40rpx 0 20rpx;
}

.history-loading-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--gray3);
}

.history-loading-dot.dot1 { animation: bounce 1.2s infinite ease-in-out 0s; }
.history-loading-dot.dot2 { animation: bounce 1.2s infinite ease-in-out 0.2s; }
.history-loading-dot.dot3 { animation: bounce 1.2s infinite ease-in-out 0.4s; }

.history-loading-text {
  font-size: 24rpx;
  color: var(--text3);
  margin-left: 8rpx;
}

/* ===== History Divider ===== */
.history-divider {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 24rpx 0 32rpx;
}

.history-divider-line {
  flex: 1;
  height: 1rpx;
  background: var(--gray2);
}

.history-divider-text {
  font-size: 22rpx;
  color: var(--text3);
  white-space: nowrap;
  background: var(--gray2);
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

/* ===== Chat Bottom Spacer ===== */
.chat-bottom {
  height: 32rpx;
}

/* ===== Input Bar ===== */
.chat-input-bar {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 100;
  box-sizing: border-box;
  background: #fff;
  border-top: 1rpx solid var(--gray2);
  /* 有原生 tabBar 时不要再加 safe-area-inset-bottom，否则会与 tab 之间多出一段空白 */
  padding: 16rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.chat-btn {
  width: 65rpx;
  height: 65rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.send-btn {
  background: var(--gray2);
  transition: background 0.2s;
}

.send-btn.active {
  background: linear-gradient(135deg, var(--green), var(--green-dk));
  box-shadow: 0 8rpx 24rpx rgba(39, 174, 96, 0.3);
}

.send-icon {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

/* input 包裹容器：承载边框与图标 */
.chat-input-wrap {
  flex: 1;
  height: 80rpx;
  background: #fff;
  border: 1rpx solid var(--gray2);
  border-radius: 40rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

/* 相机图标放在 input 内左侧 */
.input-camera-btn {
  width: 50rpx;
  height: 50rpx;
  flex-shrink: 0;
  opacity: 0.5;
}

.chat-input {
  flex: 1;
  height: 100%;
  background: transparent;
  border: none;
  padding: 0;
  font-size: 28rpx;
  color: var(--text);
}

.chat-input-placeholder {
  color: #ccc;
  font-size: 26rpx;
}

/* ── 档案引导卡片 ── */
.profile-guide-card {
  width: 100%;
  box-sizing: border-box;
  background: linear-gradient(165deg, #ffffff 0%, #f8fdf9 45%, #ecf8f0 100%);
  border-radius: 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(46, 125, 50, 0.2);
  box-shadow: 0 4rpx 24rpx rgba(46, 125, 50, 0.1);
}

.pg-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 28rpx 20rpx;
  background: linear-gradient(135deg, rgba(232, 245, 233, 0.9) 0%, rgba(255, 255, 255, 0.5) 100%);
}

.pg-emoji {
  font-size: 48rpx;
  line-height: 1;
}

.pg-header-text {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.pg-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #1b5e20;
  letter-spacing: 1rpx;
}

.pg-sub {
  font-size: 22rpx;
  color: #689f38;
  line-height: 1.4;
}

.pg-body {
  padding: 8rpx 28rpx 24rpx;
}

.pg-row {
  margin-bottom: 20rpx;
}

.pg-label {
  display: block;
  font-size: 22rpx;
  font-weight: 600;
  color: #78909c;
  margin-bottom: 12rpx;
}

.pg-chips {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
}

.pg-chip {
  font-size: 22rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(236, 239, 241, 0.95);
  color: #546e7a;
  border: 1rpx solid rgba(84, 110, 122, 0.15);
}

.pg-chip-req {
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
  color: #2e7d32;
  font-weight: 600;
  border-color: rgba(76, 175, 80, 0.35);
}

.pg-chip-warn {
  background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);
  color: #e65100;
  font-weight: 600;
  border-color: rgba(255, 152, 0, 0.4);
}

.pg-example {
  margin-top: 8rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.85);
  border: 1rpx dashed rgba(129, 199, 132, 0.5);
}

.pg-example-label {
  display: block;
  font-size: 20rpx;
  color: #81c784;
  margin-bottom: 10rpx;
  font-weight: 600;
}

.pg-example-text {
  font-size: 24rpx;
  color: #37474f;
  line-height: 1.55;
}

.pg-missing {
  padding: 0 28rpx 24rpx;
  border-top: 1rpx solid rgba(129, 199, 132, 0.2);
  padding-top: 20rpx;
}

.pg-missing-title {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #ef6c00;
  margin-bottom: 14rpx;
}

.pg-banner {
  padding: 18rpx 28rpx 28rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

.pg-banner-warn {
  color: #bf360c;
  background: linear-gradient(90deg, rgba(255, 243, 224, 0.95) 0%, rgba(255, 255, 255, 0) 100%);
  border-top: 1rpx solid rgba(255, 152, 0, 0.25);
}

.pg-banner-info {
  color: #1565c0;
  background: linear-gradient(90deg, rgba(227, 242, 253, 0.95) 0%, rgba(255, 255, 255, 0) 100%);
  border-top: 1rpx solid rgba(33, 150, 243, 0.2);
}

.profile-guide-card--compact {
  padding: 0;
}

.pg-banner-only {
  border-top: none;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
}

/* ── 档案 / 每日摄入计划卡片 ── */
.profile-plan-card {
  margin: 8rpx 0 28rpx;
  padding-bottom: 28rpx;
  width: 100%;
  box-sizing: border-box;
  background: linear-gradient(165deg, #ffffff 0%, #f8fbff 50%, #eef6ff 100%);
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow:
    0 2rpx 12rpx rgba(25, 118, 210, 0.08),
    0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(66, 165, 245, 0.3);
}

.profile-plan-meta--small {
  font-size: 22rpx;
  color: var(--text3);
  line-height: 1.5;
  margin-top: 4rpx;
}

.profile-plan-meta {
  padding: 0 36rpx 8rpx;
  font-size: 24rpx;
  color: #78909c;
}

.profile-plan-bmi {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 16rpx;
  padding: 0 36rpx 12rpx;
}

.profile-bmi-val {
  font-size: 32rpx;
  font-weight: 800;
  color: #1565c0;
}

.profile-bmi-cat {
  font-size: 26rpx;
  color: #546e7a;
  font-weight: 600;
}

.profile-plan-eval {
  padding: 0 36rpx 16rpx;
  font-size: 26rpx;
  color: #37474f;
  line-height: 1.55;
}

.profile-plan-kcal {
  padding: 0 36rpx 8rpx;
}

.profile-plan-extra {
  padding: 12rpx 36rpx 16rpx;
  font-size: 22rpx;
  color: #78909c;
  line-height: 1.5;
}

/* ── 营养确认卡片（待确认）── 渐变质感，与气泡同宽 ── */
.confirm-card {
  margin: 8rpx 0;
  width: 100%;
  box-sizing: border-box;
  background: linear-gradient(165deg, #ffffff 0%, #f8fdf9 50%, #f0f9f2 100%);
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow:
    0 2rpx 12rpx rgba(46, 125, 50, 0.06),
    0 8rpx 32rpx rgba(0, 0, 0, 0.08),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(102, 187, 106, 0.25);
}

.confirm-card--done {
  opacity: 0.85;
  padding-bottom: 28rpx;
}

.confirm-card-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 36rpx 0;
}

.confirm-card-title {
  font-size: 26rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #2e7d32 0%, #43a047 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}

.confirm-card-badge {
  font-size: 22rpx;
  color: #388e3c;
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
  padding: 6rpx 18rpx;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(76, 175, 80, 0.2);
}

.confirm-card-badge--rejected {
  color: #757575;
  background: linear-gradient(135deg, #fafafa 0%, #eeeeee 100%);
}

.confirm-card-food {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 12rpx;
  padding: 20rpx 36rpx 0;
}

.confirm-card-food-name {
  font-size: 36rpx;
  font-weight: 800;
  color: #1a1a1a;
  letter-spacing: 1rpx;
}

.confirm-card-quantity {
  font-size: 24rpx;
  color: #8d8d8d;
}

.confirm-card-calories {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  padding: 12rpx 36rpx 0;
}

.confirm-card-kcal {
  font-size: 56rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #2e7d32 0%, #66bb6a 50%, #81c784 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  line-height: 1;
  filter: drop-shadow(0 2rpx 4rpx rgba(46, 125, 50, 0.15));
}

.confirm-card-kcal-lbl {
  font-size: 24rpx;
  color: #9e9e9e;
  margin-left: 8rpx;
}

.confirm-card-nut-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  padding: 24rpx 36rpx;
  background: linear-gradient(135deg, #f1f8e9 0%, #e8f5e9 50%, #dcedc8 100%);
  margin: 20rpx 28rpx 0;
  border-radius: 20rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.6), 0 2rpx 12rpx rgba(129, 199, 132, 0.2);
  border: 1rpx solid rgba(129, 199, 132, 0.3);
}

.confirm-card-nut-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
}

.confirm-card-nut-val {
  font-size: 30rpx;
  font-weight: 800;
}

.confirm-card-nut-val.purple {
  background: linear-gradient(135deg, #7b1fa2, #ab47bc);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}

.confirm-card-nut-val.blue {
  background: linear-gradient(135deg, #1565c0, #42a5f5);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}

.confirm-card-nut-val.orange {
  background: linear-gradient(135deg, #e65100, #ff9800);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}

.confirm-card-nut-val.gray {
  background: linear-gradient(135deg, #616161, #9e9e9e);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}

.confirm-card-nut-lbl {
  font-size: 20rpx;
  color: #8d8d8d;
}

.confirm-card-reminder {
  margin: 20rpx 28rpx 0;
  padding: 20rpx 28rpx;
  background: linear-gradient(135deg, #fff8e1 0%, #ffecb3 50%, #ffe082 100%);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #5d4037;
  line-height: 1.6;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.5), 0 2rpx 8rpx rgba(255, 193, 7, 0.15);
  border: 1rpx solid rgba(255, 193, 7, 0.25);
}

.confirm-card-actions {
  display: flex;
  flex-direction: row;
  gap: 24rpx;
  padding: 24rpx 28rpx 28rpx;
}

.confirm-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.reject-btn {
  background: linear-gradient(180deg, #fafafa 0%, #f0f0f0 100%);
  color: #757575;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
}

.accept-btn {
  background: linear-gradient(135deg, #43a047 0%, #66bb6a 40%, #81c784 100%);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(76, 175, 80, 0.4), inset 0 1rpx 0 rgba(255, 255, 255, 0.2);
}

/* ===== 今日/本周汇总卡片（进度条） ===== */
.summary-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.07);
  margin-top: 8rpx;
}

.summary-card-head {
  margin-bottom: 24rpx;
}

.summary-card-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text);
}

.summary-card-sub {
  display: block;
  font-size: 24rpx;
  color: var(--text3);
  margin-top: 8rpx;
}

.summary-metric-row {
  margin-bottom: 20rpx;
}

.summary-metric-top {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 8rpx;
}

.summary-metric-label {
  font-size: 26rpx;
  color: var(--text2);
  font-weight: 500;
}

.summary-metric-val {
  font-size: 22rpx;
  color: var(--text3);
}

.summary-metric-bar-wrap {
  height: 16rpx;
  background: var(--gray2);
  border-radius: 8rpx;
  overflow: hidden;
}

.summary-metric-bar-fill {
  height: 100%;
  border-radius: 8rpx;
  background: linear-gradient(90deg, var(--green), var(--blue));
  max-width: 100%;
  transition: width 0.35s ease;
}

.summary-meals {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--gray2);
}

.summary-meals-title {
  display: block;
  font-size: 24rpx;
  color: var(--text3);
  margin-bottom: 12rpx;
}

.summary-meal-line-wrap {
  margin-bottom: 8rpx;
}

.summary-meal-line {
  font-size: 22rpx;
  color: var(--text2);
  line-height: 1.5;
}

.summary-advice {
  margin-top: 20rpx;
  padding: 20rpx 22rpx;
  background: linear-gradient(135deg, #e8f5e9 0%, #fff8e1 100%);
  border-radius: 20rpx;
  border: 1rpx solid rgba(46, 125, 50, 0.12);
}

.summary-advice-label {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--green-dk);
  margin-bottom: 8rpx;
}

.summary-advice-text {
  font-size: 24rpx;
  color: var(--text2);
  line-height: 1.65;
}

