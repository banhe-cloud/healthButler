page {
  background: #f1f3f5;
  height: 100%;
  overflow: hidden;
}

.page {
  height: 100%;
  box-sizing: border-box;
}

.profile-page {
  height: 100%;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  background: linear-gradient(180deg, #f6faf7 0%, #eef2f0 48%, #f1f3f5 100%);
}

/* 页面 disableScroll + scroll-view，关闭 iOS 橡皮筋（bounces=false） */
.profile-scroll {
  flex: 1;
  min-height: 0;
  width: 100%;
  box-sizing: border-box;
}

.profile-scroll-inner {
  padding-bottom: 48rpx;
  box-sizing: border-box;
}

/* ===== 个人头部：头像 + 信息（与「今日数据」同款渐变） ===== */
.profile-hero {
  position: relative;
  margin: 28rpx 24rpx 0;
  padding: 22rpx 22rpx 20rpx;
  border-radius: 28rpx;
  overflow: hidden;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  box-shadow:
    0 4rpx 24rpx rgba(0, 0, 0, 0.06),
    0 1rpx 0 rgba(255, 255, 255, 0.8) inset;
  background: linear-gradient(
    165deg,
    #ffffff 0%,
    #f7fbf8 42%,
    #f2f7f4 100%
  );
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
}

/* 与 .today-panel-bg::after 一致：右上角极淡绿光 */
.profile-hero::after {
  content: '';
  position: absolute;
  right: 0;
  top: 0;
  width: 45%;
  height: 55%;
  border-radius: 0 0 0 100%;
  background: radial-gradient(
    ellipse at top right,
    rgba(82, 183, 136, 0.09) 0%,
    transparent 65%
  );
  pointer-events: none;
  z-index: 0;
}

.profile-hero > view {
  position: relative;
  z-index: 1;
}

.profile-hero-avatar-wrap {
  flex-shrink: 0;
}

.profile-hero-avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 255, 255, 0.95);
  box-shadow: 0 4rpx 14rpx rgba(46, 125, 50, 0.12);
}

.profile-hero-avatar--placeholder {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #c8e6c9 0%, #81c784 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid rgba(255, 255, 255, 0.95);
  box-shadow: 0 4rpx 14rpx rgba(46, 125, 50, 0.12);
}

.profile-hero-avatar-placeholder-icon {
  width: 52rpx;
  height: 52rpx;
  opacity: 0.92;
}

.profile-hero-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
}

/* 未登录：左文案 + 右按钮，按钮与头像/文案垂直居中对齐 */
.profile-hero-guest {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  width: 100%;
  min-width: 0;
  box-sizing: border-box;
}

.profile-hero-guest-text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
}

.profile-hero-name-wrap {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-wrap: wrap;
  align-self: flex-start;
}

.profile-hero-name {
  font-size: 32rpx;
  font-weight: 800;
  color: #1b4332;
  line-height: 1.25;
}

.profile-hero-name-hint {
  font-size: 28rpx;
  color: #adb5bd;
  font-weight: 600;
  margin-left: 4rpx;
}

.profile-tag {
  align-self: flex-start;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 18rpx;
  background: linear-gradient(135deg, #e8f5e9 0%, #f1f8e9 100%);
  border-radius: 999rpx;
  border: 1rpx solid rgba(46, 125, 50, 0.15);
}

.profile-tag--compact {
  padding: 4rpx 12rpx;
  margin-top: 2rpx;
  background: linear-gradient(135deg, rgba(232, 245, 233, 0.95) 0%, rgba(241, 248, 233, 0.85) 100%);
  border-color: rgba(46, 125, 50, 0.12);
}

.profile-tag--muted {
  background: rgba(241, 243, 245, 0.85);
  border-color: rgba(0, 0, 0, 0.06);
}

.profile-tag-emoji {
  font-size: 22rpx;
  line-height: 1;
}

.profile-tag-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #2e7d32;
  line-height: 1.25;
}

.profile-tag--muted .profile-tag-text {
  color: #6c757d;
  font-weight: 600;
}

/* 档案详情：单行混排，减少纵向高度 */
.profile-meta-compact {
  align-self: stretch;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  align-items: baseline;
  margin-top: 2rpx;
  max-width: 100%;
}

.profile-meta-compact-main {
  font-size: 22rpx;
  color: #495057;
  line-height: 1.35;
}

.profile-hint {
  align-self: stretch;
  width: 100%;
  box-sizing: border-box;
  font-size: 21rpx;
  color: #868e96;
  line-height: 1.4;
  margin-top: 0;
}

.profile-login-btn {
  flex-shrink: 0;
  align-self: center;
  margin-top: 0;
  margin-left: 0;
  margin-right: 0;
  padding: 0 32rpx;
  min-width: 0;
  width: auto !important;
  max-width: 100%;
  height: 68rpx;
  line-height: 68rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  background: linear-gradient(135deg, #2ecc71, #27ae60);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 999rpx;
  border: none;
}

.profile-login-btn::after {
  border: none;
}

/* ===== 今日数据：白底为主 + 绿色点缀（避免满眼绿） ===== */
.today-panel {
  position: relative;
  margin: 24rpx 24rpx 0;
  border-radius: 28rpx;
  overflow: hidden;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  box-shadow:
    0 4rpx 24rpx rgba(0, 0, 0, 0.06),
    0 1rpx 0 rgba(255, 255, 255, 0.8) inset;
}

.today-panel-bg {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  /* 极淡绿 + 白，整体偏干净 */
  background: linear-gradient(
    165deg,
    #ffffff 0%,
    #f7fbf8 42%,
    #f2f7f4 100%
  );
}

.today-panel-bg::after {
  content: '';
  position: absolute;
  right: 0;
  top: 0;
  width: 45%;
  height: 55%;
  border-radius: 0 0 0 100%;
  background: radial-gradient(
    ellipse at top right,
    rgba(82, 183, 136, 0.09) 0%,
    transparent 65%
  );
  pointer-events: none;
}

.today-panel-inner {
  position: relative;
  z-index: 1;
  padding: 32rpx 32rpx 36rpx;
}

.today-header {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.today-title-wrap {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.today-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #212529;
  letter-spacing: 0.5rpx;
}

.today-date {
  font-size: 22rpx;
  color: #868e96;
  font-weight: 500;
}

.behavior-pill {
  flex-shrink: 0;
  max-width: 52%;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 18rpx;
  background: #fff;
  border-radius: 999rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.04);
}

.behavior-pill-emoji {
  font-size: 28rpx;
  line-height: 1;
}

.behavior-pill-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #495057;
  line-height: 1.3;
}

.today-kcal-block {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.today-kcal-left {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 8rpx;
}

.today-kcal-num {
  font-size: 72rpx;
  font-weight: 800;
  line-height: 1;
  /* 主数字保留品牌绿，略柔和 */
  background: linear-gradient(135deg, #2d6a4f 0%, #40916c 55%, #52b788 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}

.today-kcal-unit {
  font-size: 26rpx;
  color: #868e96;
  font-weight: 600;
}

.today-kcal-divider {
  width: 2rpx;
  height: 64rpx;
  background: linear-gradient(180deg, transparent, rgba(0, 0, 0, 0.08), transparent);
  margin: 0 8rpx;
}

.today-kcal-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.today-target-label {
  font-size: 22rpx;
  color: #868e96;
}

.today-target-val {
  font-size: 30rpx;
  font-weight: 700;
  color: #343a40;
}

.today-bar-wrap {
  margin-bottom: 24rpx;
}

.today-bar-track {
  height: 18rpx;
  border-radius: 999rpx;
  background: #e9ecef;
  overflow: hidden;
  border: none;
}

.today-bar-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #52b788 0%, #2d6a4f 100%);
  transition: width 0.35s ease;
  min-width: 0;
}

.today-bar-meta {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}

.today-bar-pct {
  font-size: 22rpx;
  color: #495057;
  font-weight: 600;
}

.today-meals {
  font-size: 22rpx;
  color: #868e96;
}

/* ── 今日吃了什么 / 营养进度 ── */
.today-detail-card {
  margin-top: 20rpx;
  padding: 20rpx 18rpx 22rpx;
  background: #fff;
  border-radius: 20rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.today-detail-card--nut {
  margin-top: 20rpx;
}

.today-detail-head {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.today-detail-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #212529;
}

.today-detail-badge {
  font-size: 22rpx;
  font-weight: 600;
  color: #495057;
  background: #f1f3f5;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
}

.today-target-tip {
  font-size: 20rpx;
  color: #6c757d;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: #f1f3f5;
}

.today-target-tip--ok {
  color: #495057;
  background: #e7f5ff;
}

.today-detail-empty {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 28rpx 16rpx;
  text-align: center;
  font-size: 26rpx;
  color: #6c757d;
}

.today-detail-empty-sub {
  font-size: 22rpx;
  color: #adb5bd;
}

/* 紧凑单行：标签 | 食物·分量… | 热量 */
.eat-list-compact {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.eat-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

.eat-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.eat-pill {
  flex-shrink: 0;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 20rpx;
  font-weight: 600;
  color: #495057;
  padding: 4rpx 12rpx;
  background: #f1f3f5;
  border-radius: 8rpx;
  line-height: 1.3;
}

.eat-line {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  font-weight: 500;
  color: #212529;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.35;
}

.eat-kcal-mini {
  flex-shrink: 0;
  font-size: 24rpx;
  font-weight: 700;
  color: #343a40;
  font-variant-numeric: tabular-nums;
}

.nut-row {
  margin-bottom: 22rpx;
}

.nut-row:last-child {
  margin-bottom: 0;
}

.nut-row-top {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 10rpx;
}

.nut-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #495057;
}

.nut-val {
  font-size: 22rpx;
  color: #868e96;
}

.nut-bar-track {
  height: 16rpx;
  border-radius: 999rpx;
  background: #e9ecef;
  overflow: hidden;
}

.nut-bar-fill {
  height: 100%;
  border-radius: 999rpx;
  max-width: 100%;
  transition: width 0.35s ease;
}

/* 各营养素分色，避免五条同色绿条 */
.nut-bar-fill--cal {
  background: linear-gradient(90deg, #52b788 0%, #2d6a4f 100%);
}

.nut-bar-fill--protein {
  background: linear-gradient(90deg, #b197fc 0%, #7c3aed 100%);
}

.nut-bar-fill--carbs {
  background: linear-gradient(90deg, #74c0fc 0%, #1971c2 100%);
}

.nut-bar-fill--fat {
  background: linear-gradient(90deg, #ffc078 0%, #e8590c 100%);
}

.nut-bar-fill--fiber {
  background: linear-gradient(90deg, #8ce99a 0%, #2f9e44 100%);
}

/* ===== 登录引导弹窗 ===== */
.sheet-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.sheet-mask--over {
  z-index: 300;
}

.sheet {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 20rpx 40rpx 0;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  box-sizing: border-box;
}

.sheet--over {
  z-index: 301;
}

.sheet-show {
  transform: translateY(0);
}

.sheet-handle {
  width: 64rpx;
  height: 8rpx;
  background: #dee2e6;
  border-radius: 4rpx;
  margin: 0 auto 32rpx;
}

.sheet-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #212529;
  text-align: center;
  margin-bottom: 10rpx;
}

.sheet-subtitle {
  font-size: 24rpx;
  color: #868e96;
  text-align: center;
  line-height: 1.45;
  padding: 0 16rpx;
  margin-bottom: 36rpx;
}

.sheet-subtitle--left {
  text-align: left;
  margin-bottom: 20rpx;
  color: #868e96;
  font-size: 24rpx;
}

.sheet-avatar-wrap {
  display: flex;
  justify-content: center;
  margin-bottom: 32rpx;
}

.sheet-avatar-btn {
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  width: 160rpx;
  height: 160rpx;
}

.sheet-avatar-btn::after { border: none; }

.sheet-avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 255, 255, 0.95);
  box-shadow: 0 4rpx 18rpx rgba(46, 125, 50, 0.12);
  box-sizing: border-box;
}

.sheet-avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  box-sizing: border-box;
  background: linear-gradient(155deg, #f4f6f8 0%, #e9ecef 48%, #e8f5e9 100%);
  border: 2rpx solid rgba(45, 106, 79, 0.1);
  box-shadow:
    0 4rpx 20rpx rgba(0, 0, 0, 0.06),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.85);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.sheet-avatar-placeholder-icon {
  width: 72rpx;
  height: 72rpx;
  opacity: 0.78;
}

.sheet-avatar-tip {
  font-size: 22rpx;
  color: #6c757d;
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

/* 昵称：表单块 + 白底描边，避免与微信原生昵称面板叠成「双层灰条」 */
.sheet-field {
  margin-bottom: 32rpx;
}

.sheet-field-head {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
  margin-bottom: 16rpx;
  padding: 0 4rpx;
}

.sheet-field-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #212529;
  letter-spacing: 0.5rpx;
}

.sheet-field-desc {
  font-size: 22rpx;
  color: #868e96;
  line-height: 1.4;
}

.sheet-input-shell {
  background: #fff;
  border: 2rpx solid #e9ecef;
  border-radius: 20rpx;
  padding: 0 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  box-sizing: border-box;
}

.sheet-nickname-input {
  width: 100%;
  height: 96rpx;
  min-height: 96rpx;
  background: transparent;
  border-radius: 0;
  padding: 0;
  font-size: 30rpx;
  font-weight: 600;
  color: #212529;
  box-sizing: border-box;
  text-align: left;
}

.sheet-nickname-placeholder {
  color: #adb5bd;
  font-weight: 400;
  font-size: 28rpx;
}

.sheet-logout-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #fff5f5;
  color: #c92a2a;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: 1rpx solid rgba(201, 42, 42, 0.2);
  margin-bottom: 24rpx;
}

.sheet-logout-btn::after {
  border: none;
}

.sheet-confirm-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #2ecc71, #27ae60);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(39, 174, 96, 0.3);
}

.sheet-confirm-btn::after { border: none; }

.sheet-cancel-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: transparent;
  color: #adb5bd;
  font-size: 28rpx;
  border: none;
}

.sheet-cancel-btn::after { border: none; }
